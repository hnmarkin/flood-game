.card {
    width: auto;
    padding: 14px;
    border-radius: 12px;
    background-color: rgba(30, 30, 30, 0.85);
    border-width: 1px;
    border-color: rgba(255, 255, 255, 0.15);
    overflow: hidden;
    color: rgb(255, 255, 255);
    flex-wrap: wrap;
    height: auto;
    min-height: 170px;
   
    flex-direction: column;
    text-overflow: ellipsis;
    border-bottom-width: 5px;
    border-top-width: 5px;
    border-left-width: 5px;
    border-right-width: 5px;
    transition-property: border-color;
    transition-duration: 0.8s;
    
}

.card {
    display: flex;
    background-color: var(--card-body);
    border-color: var(--outline-dark);
    border-width: 4px;
    border-radius: 0px;
    /* “pixel” shadow */
    box-shadow: 4px 4px 0px var(--shadow);
    padding: 0px;      /* header/body handle padding */
    min-height: 140px; /* smaller so you can fit 4 on a page */
    color: var(--text-dark);
}

.card:hover {
    /* subtle highlight */
    border-color: rgb(255,255,255);
}


.card Label {
    white-space: normal;
    color: var(--text-dark);
    font-size: 11px;
}

.card:hover {
    border-color: rgba(255, 255, 255, 0.35);
}

.card-header {
    background-color: var(--panel-blue);
    border-bottom-width: 4px;
    border-bottom-color: var(--outline-dark);

    padding: 8px 10px;
}

.card-title {
    color: var(--text-light);
    font-size: 14px;
    -unity-font-style: bold;
    white-space: normal;
}

.card-body {
    padding: 10px;
}

.card-description {
    font-size: 11px;
    white-space: normal;
    /* clamp */
    max-height: 54px;
    overflow: hidden;
}

.card-description {
    display: none;
}

.card.featured-on {
    border-color: var(--badge-green);
}

.card.featured-off {
    border-color: rgba(0, 210, 90, 0.35);
}

