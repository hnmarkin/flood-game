.screen {
    position: absolute;
    left: 0; right: 0; top: 0; bottom: 0;

    background-color: var(--bg-teal);
    padding: 18px;
}

.screen-root {
    width: 100%;
    height: 100%;
    background-color: var(--bg-teal);
}

.screen-title {
    color: var(--text-light);
    background-color: var(--panel-blue);
    border-color: var(--outline-dark);
    border-width: 4px;

    padding: 10px 12px;
    margin-bottom: 12px;

    font-size: 18px;
    -unity-font-style: bold;

    /* retro = sharp corners */
    border-radius: 0px;
    unity-text-align: middle-center;
}

/* Ensure scroll fills remaining space */
.scroll {
    flex-grow: 1;
}

.card Label {
    white-space: normal;
}

/* THIS is the grid container */
.cards-container {
    width: 100%;
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;

    justify-content: flex-start;
    align-items: stretch;
    align-content: flex-start;

    /* small inner padding so cards don't touch edges */
    padding: 4px;
}

/* THE MOST IMPORTANT LINE:
   The direct children of cards-container are the template instances (wrappers).
   We size THEM, not the inner .card.
*/
.cards-container > * {
    flex-grow: 0;
    flex-shrink: 1;

    /* two per row */
    flex-basis: 48%;

    /* spacing between tiles */
    margin: 0.5%;
}

.unity-base-slider__tracker {
    background-color: rgba(255,255,255,0.08);
    border-radius: 999px;
}

.unity-base-slider__dragger {
    background-color: rgba(255,255,255,0.35);
    border-radius: 999px;
    min-height: 24px;
}


/* Hide scrollbars (different Unity versions use different internal classes) */
.unity-scroll-view__vertical-scroller,
.unity-scroll-view__horizontal-scroller,
.unity-scroll-view__vertical-scroller-container,
.unity-scroll-view__horizontal-scroller-container,
.unity-scroller,
.unity-scroller--vertical,
.unity-scroller--horizontal {
    display: none;
    visibility: hidden;
    width: 0px;
    height: 0px;
}