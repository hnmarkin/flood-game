<ui:UXML xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" noNamespaceSchemaLocation="../../../../../UIElementsSchema/UIElements.xsd" editor-extension-mode="False">
    <Style src="project://database/Assets/Dev/Dev_Scripts/UI_UXML_USS/UI%20Editor/Quiz.uss?fileID=7433441132597879392&amp;guid=70d79d66f87604289b63a6d64e6994e4&amp;type=3#Quiz" />
    <ui:VisualElement name="quiz_root" class="quiz-root" style="flex-grow: 0; height: auto; width: 50%; justify-content: space-between; align-items: stretch; align-self: center; margin-top: 0; padding-top: 0; padding-bottom: 0; margin-bottom: 0; max-height: none; align-content: flex-start; flex-wrap: nowrap; position: relative; top: auto; background-image: url(&quot;project://database/Assets/Dev/Ash_dev/dev_imgs/UI_imgs/UI%20Panels/Panel_02.png?fileID=21300000&amp;guid=3c1f24a9c7abd48b2a53e227dc307cdd&amp;type=3#Panel_02&quot;); min-height: auto; flex-direction: column;">
        <ui:VisualElement name="quiz_container" class="quiz-container" style="flex-grow: 1; background-image: none; margin-top: 0; margin-bottom: 0; padding-bottom: 0; padding-top: 0; margin-right: 0; margin-left: 0; padding-right: 0; padding-left: 0; height: auto;">
            <ui:Label text="Pop-up Quiz" name="quiz_heading" style="-unity-font-definition: url(&quot;project://database/Assets/Dev/Ash_dev/Pixel_Font/PublicPixel.ttf?fileID=12800000&amp;guid=29da3f0434479411c8f4a5469b7d44d9&amp;type=3#PublicPixel&quot;); color: rgb(255, 255, 255); -unity-text-align: middle-center; text-shadow: 2px 2px 0 rgb(0, 0, 0); -unity-text-outline-width: 0; margin-left: 10px; padding-left: 2px; margin-right: 10px; margin-top: 10px; margin-bottom: 2px; font-size: 12px; max-width: none; padding-bottom: 2px;">
                <ui:Button name="quiz_close_button" style="max-width: 15%; justify-content: flex-start; align-self: flex-end; background-image: url(&quot;project://database/Assets/Dev/Ash_dev/dev_imgs/UI_imgs/UI%20buttons/Exit_Button_03.png?fileID=21300000&amp;guid=45f44db7e5783402e9641b9a89fef520&amp;type=3#Exit_Button_03&quot;); background-color: rgba(255, 255, 255, 0); background-size: 100% 100%; padding-top: 10px; padding-left: 10px; padding-right: 10px; margin-left: 2px; margin-right: 2px; align-content: flex-start; align-items: stretch; border-left-color: rgba(255, 255, 255, 0); border-right-color: rgba(255, 255, 255, 0); border-top-color: rgba(255, 255, 255, 0); border-bottom-color: rgba(255, 255, 255, 0);" />
            </ui:Label>
            <ui:GroupBox name="quiz_groupbox" class="quiz-groupbox" style="margin-top: 2px; padding-top: 2px; padding-bottom: 2px;">
                <ui:Label text="Label" name="quiz_question" class="quiz-question" style="margin-left: 8px; margin-right: 8px; padding-left: 2px; -unity-font-definition: url(&quot;project://database/Assets/Dev/Ash_dev/Pixel_Font/PublicPixel.ttf?fileID=12800000&amp;guid=29da3f0434479411c8f4a5469b7d44d9&amp;type=3#PublicPixel&quot;); font-size: 7px; text-shadow: 1px 1px 0 rgb(0, 0, 0); color: rgb(255, 255, 255); white-space: normal;" />
                <ui:Button text="Button" name="option1" class="quiz-option" style="-unity-font-definition: url(&quot;project://database/Assets/Dev/Ash_dev/Pixel_Font/PublicPixel.ttf?fileID=12800000&amp;guid=29da3f0434479411c8f4a5469b7d44d9&amp;type=3#PublicPixel&quot;); font-size: 6px; color: rgb(255, 255, 255); text-shadow: 1px 1px 0 rgb(0, 0, 0); border-left-color: rgba(255, 255, 255, 0); border-right-color: rgba(255, 255, 255, 0); border-top-color: rgba(255, 255, 255, 0); border-bottom-color: rgba(255, 255, 255, 0); margin-right: 6px; transition-property: all; transition-duration: 0s; transition-timing-function: ease; transition-delay: 0s; height: auto; white-space: normal;" />
                <ui:Button text="Button" name="option2" class="quiz-option" style="-unity-font-definition: url(&quot;project://database/Assets/Dev/Ash_dev/Pixel_Font/PublicPixel.ttf?fileID=12800000&amp;guid=29da3f0434479411c8f4a5469b7d44d9&amp;type=3#PublicPixel&quot;); font-size: 6px; color: rgb(255, 255, 255); text-shadow: 1px 1px 0 rgb(0, 0, 0); border-left-color: rgba(255, 255, 255, 0); border-right-color: rgba(255, 255, 255, 0); border-top-color: rgba(255, 255, 255, 0); border-bottom-color: rgba(255, 255, 255, 0); margin-right: 6px; height: auto; white-space: normal;" />
                <ui:Button text="Button" name="option3" class="quiz-option" style="-unity-font-definition: url(&quot;project://database/Assets/Dev/Ash_dev/Pixel_Font/PublicPixel.ttf?fileID=12800000&amp;guid=29da3f0434479411c8f4a5469b7d44d9&amp;type=3#PublicPixel&quot;); font-size: 6px; color: rgb(255, 255, 255); text-shadow: 1px 1px 0 rgb(0, 0, 0); border-left-color: rgba(255, 255, 255, 0); border-right-color: rgba(255, 255, 255, 0); border-top-color: rgba(255, 255, 255, 0); border-bottom-color: rgba(255, 255, 255, 0); margin-right: 6px; height: auto; white-space: normal;" />
            </ui:GroupBox>
            <ui:GroupBox name="explanation_box" style="visibility: visible; display: none; margin-top: 2px; padding-top: 4px; padding-bottom: 4px;">
                <ui:Label text="Label" name="explanation_result" style="margin-left: 8px; margin-right: 8px; -unity-font-definition: url(&quot;project://database/Assets/Dev/Ash_dev/Pixel_Font/PublicPixel.ttf?fileID=12800000&amp;guid=29da3f0434479411c8f4a5469b7d44d9&amp;type=3#PublicPixel&quot;); font-size: 8px; text-shadow: 1px 1px 0 rgb(0, 0, 0); color: rgb(255, 255, 255); margin-top: 2px; padding-top: 2px; white-space: normal;" />
                <ui:Label text="Label" name="explanation_label" style="margin-left: 8px; margin-right: 8px; -unity-font-definition: url(&quot;project://database/Assets/Dev/Ash_dev/Pixel_Font/PublicPixel.ttf?fileID=12800000&amp;guid=29da3f0434479411c8f4a5469b7d44d9&amp;type=3#PublicPixel&quot;); font-size: 6px; text-shadow: 1px 1px 0 rgb(0, 0, 0); color: rgb(255, 255, 255); white-space: normal;" />
            </ui:GroupBox>
            <ui:Button text="Continue" name="quiz_continue_btn" style="margin-right: 10px; margin-left: 10px; margin-bottom: 12px; margin-top: 4px; background-color: rgba(188, 188, 188, 0); border-left-color: rgba(149, 149, 149, 0); border-right-color: rgba(149, 149, 149, 0); border-top-color: rgba(149, 149, 149, 0); border-bottom-color: rgba(149, 149, 149, 0); background-image: url(&quot;project://database/Assets/Dev/Ash_dev/dev_imgs/UI_imgs/UI%20buttons/Blue_Button_01.png?fileID=2800000&amp;guid=0a0e2856922a1474ab9541dd2f949ad1&amp;type=3#Blue_Button_01&quot;); font-size: 8px; -unity-font-definition: url(&quot;project://database/Assets/Dev/Ash_dev/Pixel_Font/PublicPixel.ttf?fileID=12800000&amp;guid=29da3f0434479411c8f4a5469b7d44d9&amp;type=3#PublicPixel&quot;); color: rgb(255, 255, 255); max-width: 100px; max-height: 40px; align-self: flex-end;" />
        </ui:VisualElement>
    </ui:VisualElement>
</ui:UXML>
