                <ui:Button text="Start Game" name="start_btn" class="start-btn menu-btn" style="-unity-font-definition: url(&quot;project://database/Assets/Dev/Ash_dev/Pixel_Font/PublicPixel.ttf?fileID=12800000&amp;guid=29da3f0434479411c8f4a5469b7d44d9&amp;type=3#PublicPixel&quot;); color: rgb(255, 255, 255); text-shadow: 2px 2px 0 rgb(76, 76, 76); margin-bottom: 0; white-space: normal; background-color: rgba(188, 188, 188, 0); border-top-width: 0; border-right-width: 0; border-bottom-width: 0; border-left-width: 0; background-image: url(&quot;project://database/Assets/Dev/Ash_dev/dev_imgs/UI_imgs/Blue_Button_01.png?fileID=21300000&amp;guid=0a0e2856922a1474ab9541dd2f949ad1&amp;type=3#Blue_Button_01&quot;); background-size: 100% 100%; -unity-text-align: middle-center; font-size: 8px; overflow: hidden; position: relative; flex-wrap: wrap; width: 20%; margin-top: 0; margin-right: 0; margin-left: 0; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0; align-items: stretch; justify-content: flex-start; align-self: center; height: 10%;" />
                <ui:Button text="Settings" name="main_menu_btn" class="main-menu-btn menu-btn" style="-unity-font-definition: url(&quot;project://database/Assets/Dev/Ash_dev/Pixel_Font/PublicPixel.ttf?fileID=12800000&amp;guid=29da3f0434479411c8f4a5469b7d44d9&amp;type=3#PublicPixel&quot;); color: rgb(255, 255, 255); white-space: normal; text-shadow: 2px 2px 0 rgb(76, 76, 76); margin-bottom: 2px; background-color: rgba(188, 188, 188, 0); border-top-width: 0; border-right-width: 0; border-bottom-width: 0; border-left-width: 0; background-image: url(&quot;project://database/Assets/Dev/Ash_dev/dev_imgs/UI_imgs/Blue_Button_01.png?fileID=21300000&amp;guid=0a0e2856922a1474ab9541dd2f949ad1&amp;type=3#Blue_Button_01&quot;); background-size: 100% 100%; font-size: 8px; flex-wrap: wrap; align-self: center; width: 20%; margin-top: 5px; margin-right: 4px; margin-left: 4px; height: 10%; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0;" />
