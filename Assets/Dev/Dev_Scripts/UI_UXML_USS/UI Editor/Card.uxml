<ui:UXML xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" noNamespaceSchemaLocation="../../../../UIElementsSchema/UIElements.xsd" editor-extension-mode="False">
    <Style src="project://database/Assets/Dev/Dev_Scripts/UI_UXML_USS/UI%20Editor/Card.uss?fileID=7433441132597879392&amp;guid=8b25bcdfcb7f2457fa9896393f26c8ec&amp;type=3#Card" />
    <ui:VisualElement name="card_root" class="card root" style="flex-grow: 1; width: auto; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0; max-height: none; max-width: none; margin-top: 5px; margin-right: 5px; margin-bottom: 5px; margin-left: 5px; background-color: rgba(0, 0, 0, 0); height: auto; min-height: auto; flex-direction: column; font-size: 5px; border-top-left-radius: 4px; border-top-right-radius: 4px; border-bottom-right-radius: 4px; border-bottom-left-radius: 4px; color: rgb(255, 255, 255); background-image: url(&quot;project://database/Assets/Dev/Ash_dev/dev_imgs/UI_imgs/Panel_02.png?fileID=21300000&amp;guid=3c1f24a9c7abd48b2a53e227dc307cdd&amp;type=3#Panel_02&quot;); flex-wrap: nowrap; -unity-font-definition: url(&quot;project://database/Assets/Dev/Ash_dev/Pixel_Font/PublicPixel.ttf?fileID=12800000&amp;guid=29da3f0434479411c8f4a5469b7d44d9&amp;type=3#PublicPixel&quot;); white-space: nowrap; flex-shrink: 1;">
        <ui:VisualElement name="card_container" class="card-container" style="flex-grow: 0; top: 1%; height: auto; bottom: auto; max-height: 75%; flex-wrap: nowrap; flex-shrink: 0;">
            <ui:Label text="Label" name="card_title" class="card-title" style="font-size: 6px; white-space: normal; background-color: rgba(0, 0, 0, 0); flex-wrap: nowrap; margin-bottom: 0; margin-right: 0; margin-top: 0; margin-left: 0; color: rgb(255, 255, 255); top: 0%; right: 0%; left: 0%; padding-left: 4%; padding-top: 10px;" />
            <ui:VisualElement name="card_status" class="card-stats-row meta-row" style="flex-grow: 0; background-color: rgba(0, 0, 0, 0); border-left-width: 10px; flex-wrap: nowrap; font-size: 5px; top: 5%; bottom: auto; max-height: none; max-width: none; align-self: auto; justify-content: flex-start; flex-shrink: 0; border-bottom-width: 10px; border-right-width: 10px; border-top-width: 0;">
                <ui:Label text="Label" name="money" class="pill" style="font-size: 5px; white-space: normal; padding-top: 2px; margin-top: 0; color: rgb(255, 255, 255); flex-wrap: wrap; height: auto; text-shadow: 1px 0 0 rgba(0, 0, 0, 0);" />
                <ui:Label text="Label" name="action_points" class="pill" style="font-size: 5px; white-space: normal; margin-top: 0; padding-top: 2px; color: rgb(255, 255, 255); flex-wrap: wrap; text-shadow: 1px 0 0 rgba(0, 0, 0, 0);" />
                <ui:Label text="Label" name="card_type" class="card-type" style="font-size: 5px; white-space: normal; padding-top: 2px; margin-top: 0; height: auto; color: rgb(255, 255, 255); flex-wrap: wrap; text-shadow: 1px 0 0 rgba(0, 0, 0, 0);" />
                <ui:Label text="Label" name="effects" class="card-effects" style="font-size: 5px; white-space: normal; padding-top: 2px; margin-top: 0; color: rgb(255, 255, 255); flex-wrap: wrap; text-shadow: 1px 0 0 rgba(0, 0, 0, 0); height: auto;" />
                <ui:Label text="Label" name="card_description" enabled="true" class="card-effects" style="font-size: 5px; white-space: normal; padding-top: 2px; margin-top: 0; color: rgb(255, 255, 255); flex-wrap: wrap; display: flex; width: auto; overflow: visible; text-shadow: 1px 0 0 rgba(0, 0, 0, 0);" />
            </ui:VisualElement>
        </ui:VisualElement>
    </ui:VisualElement>
</ui:UXML>
